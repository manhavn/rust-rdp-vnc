<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.manhavn.rust-rdp-vnc</id>
  <name>Rust RDP VNC</name>
  <summary>RDP and VNC remote desktop client</summary>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <developer id="io.github.manhavn">
    <name>RustAI</name>
  </developer>
  <description>
    <p>
      Rust RDP VNC is a remote desktop client built around a shared Rust protocol core.
      Connect to Microsoft Remote Desktop (RDP) and VNC servers from Linux.
    </p>
    <p>Features:</p>
    <ul>
      <li>RDP sessions via IronRDP</li>
      <li>VNC sessions</li>
      <li>Open and save .rdp / .vnc connection files</li>
      <li>Zoom, fullscreen, keyboard and mouse input</li>
    </ul>
  </description>
  <launchable type="desktop-id">io.github.manhavn.rust-rdp-vnc.desktop</launchable>
  <url type="homepage">https://github.com/manhavn/rust-rdp-vnc</url>
  <url type="bugtracker">https://github.com/manhavn/rust-rdp-vnc/issues</url>
  <url type="vcs-browser">https://github.com/manhavn/rust-rdp-vnc</url>
  <screenshots>
    <screenshot type="default">
      <caption>Rust RDP VNC connection panel and remote desktop view</caption>
      <image type="source" width="1400" height="900">https://raw.githubusercontent.com/manhavn/rust-rdp-vnc/main/desktop/assets/screenshots/main.png</image>
    </screenshot>
  </screenshots>
  <releases>
    <release version="1.0.0" date="2026-07-20">
      <description>
        <p>Initial Flathub packaging of the Linux desktop client (RDP + VNC).</p>
      </description>
    </release>
  </releases>
  <content_rating type="oars-1.1"/>
  <categories>
    <category>Network</category>
    <category>RemoteAccess</category>
  </categories>
</component>
